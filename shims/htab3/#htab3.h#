#ifndef HTAB3_H
#define HTAB3_H

#include <cstdlib>
#include <cstring>
#include <cassert>

typedef unsigned long htab3_ind_t;
typedef unsigned long htab3_size_t;
typedef unsigned htab3_hash_t;

static constexpr htab3_ind_t HTAB3_EMPTY_IND = 0xfffffffe;
static constexpr htab3_ind_t HTAB3_DELETED_IND = 0xffffffff;

enum htab3_action { HTAB3_FIND, HTAB3_INSERT, HTAB3_REPLACE, HTAB3_DELETE };

template<typename El>
struct hbin3_t {
  htab3_size_t els_start, els_bound;
  El *els;
  htab3_size_t els_capacity;
  char *deleted;
  htab3_size_t deleted_capacity;
  htab3_ind_t *entries;
  htab3_size_t entries_capacity;
};

template<typename El, typename Hash, typename Eq>
struct htab3_t {
  htab3_size_t els_num;
  hbin3_t<El> bin;

  static void create (htab3_t *htab, htab3_size_t min_size) {
    htab3_size_t size;
    for (size = 2; min_size > size; size *= 2);
    htab->els_num = 0;
    auto &b = htab->bin;
    b.els_start = b.els_bound = 0;
    b.els = (El *) std::malloc (size * sizeof (El));
    b.els_capacity = size;
    htab3_size_t del_bytes = (size + 7) / 8;
    b.deleted = (char *) std::calloc (del_bytes, 1);
    b.deleted_capacity = del_bytes;
    b.entries = (htab3_ind_t *) std::malloc (2 * size * sizeof (htab3_ind_t));
    b.entries_capacity = 2 * size;
    for (htab3_size_t i = 0; i < 2 * size; i++) b.entries[i] = HTAB3_EMPTY_IND;
  }

  static void destroy_bin (hbin3_t<El> &b) {
    std::free (b.els);
    std::free (b.deleted);
    std::free (b.entries);
  }

  static void destroy (htab3_t *htab) {
    destroy_bin (htab->bin);
    htab->els_num = 0;
  }

  static bool do_1 (htab3_t *htab, hbin3_t<El> &bin, El &el,
                    enum htab3_action action, El **res) {
    htab3_ind_t el_ind, *entry, *first_deleted_entry = nullptr;
    htab3_size_t mask = bin.entries_capacity - 1;
    Hash hash_fn;
    Eq eq_fn;
    htab3_hash_t hash = hash_fn (el), peterb;
 
    peterb = hash;
    htab3_size_t ind = hash & mask;
    for (;;) {
      entry = bin.entries + ind;
      el_ind = *entry;
      if (el_ind < HTAB3_EMPTY_IND) {
        if (eq_fn (bin.els[el_ind], el)) {
          if (action != HTAB3_DELETE) {
            *res = &bin.els[el_ind];
          } else {
            htab->els_num--;
            bin.deleted[el_ind / 8] |= 1 << (el_ind % 8);
            *entry = HTAB3_DELETED_IND;
          }
          return true;
        }
      } else if (el_ind != HTAB3_DELETED_IND) {
        if (action == HTAB3_INSERT || action == HTAB3_REPLACE) {
          htab->els_num++;
          if (first_deleted_entry != nullptr) entry = first_deleted_entry;
          *res = &bin.els[bin.els_bound];
          *entry = bin.els_bound++;
        }
        return false;
      } else {
        first_deleted_entry = entry;
      }
      peterb >>= 11;
      ind = (5 * ind + peterb + 1) & mask;
    }
  }

  static bool do_ (htab3_t *htab, El &el, enum htab3_action action, El **res) {
    htab3_size_t els_size = htab->bin.els_capacity;
    if (action != HTAB3_DELETE && htab->bin.els_bound >= els_size) {
      htab3_size_t size = htab->bin.entries_capacity;
      if (2 * htab->els_num >= size) {
        size *= 2;
        els_size *= 2;
      }
      hbin3_t<El> resize_bin;
      resize_bin.els = (El *) std::malloc (els_size * sizeof (El));
      resize_bin.els_capacity = els_size;
      htab3_size_t del_bytes = (els_size + 7) / 8;
      resize_bin.deleted = (char *) std::calloc (del_bytes, 1);
      resize_bin.deleted_capacity = del_bytes;
      resize_bin.entries = (htab3_ind_t *) std::malloc (size * sizeof (htab3_ind_t));
      resize_bin.entries_capacity = size;
      for (htab3_size_t j = 0; j < size; j++) resize_bin.entries[j] = HTAB3_EMPTY_IND;
      resize_bin.els_start = resize_bin.els_bound = 0;
      htab3_size_t bound = htab->bin.els_bound;
      htab3_size_t saved_els_num = htab->els_num;
      for (htab3_size_t i = htab->bin.els_start; i < bound; i++)
        if (!(htab->bin.deleted[i / 8] & (1 << (i % 8)))) {
          El *r;
          do_1 (htab, resize_bin, htab->bin.els[i], HTAB3_INSERT, &r);
          *r = htab->bin.els[i];
        }
      htab->els_num = saved_els_num;
      destroy_bin (htab->bin);
      htab->bin = resize_bin;
    }
    return do_1 (htab, htab->bin, el, action, res);
  }

  static htab3_size_t size (htab3_t *htab) {
    return htab->bin.entries_capacity / 2;
  }
};

#endif /* #ifndef HTAB3_H */
